<body>

   <!-- Top Bar -->
  <div class="top-bar">
    <span>🚨 Emergency: Call 108 / +91-8000-123-911</span>
    <span>📧 support@meditrack.health</span>
    <span>24x7 Meditrack Command Center</span>
  </div>

<!-- NAV -->
<nav>
  <a class="nav-brand" href="#">
    <div class="nav-logo">MT</div>
    <div>
      <div class="nav-title">MediTrack</div>
      <div class="nav-sub">Patient Suffering Intelligence System</div>
    </div>
  </a>
  <div class="nav-right">
    <div class="guest-chip">
      <div class="guest-avatar">MT</div>
      <span class="guest-name">Guest</span>
    </div>
    <button class="btn-logout">Logout</button>
  </div>
</nav>

<!-- MAIN -->
<main>
  <div class="page-header">
    <h1>Patient Dashboard</h1>
    <p>Real-time status &amp; queue insights</p>
  </div>

  <div class="grid">

    <!-- Patient Info -->
    <div class="card">
      <div class="card-header">
        <span class="card-title">Patient Info</span>
        <!-- <span class="badge badge-red">Critical</span> -->
      </div> 
      <!-- data recieve and show on card -->

      <div class="info-rows">
        <div class="info-row"><span class="info-label">Name</span><span class="info-value"><%= patient.fullName %></span></div>
        <div class="info-row"><span class="info-label">Patient ID</span><span class="info-value">MT-PAT-<%= Math.floor(Math.random() * (1000 - 100 + 1)) + 100 %></span></div>
        <div class="info-row"><span class="info-label">Token Number</span><span class="info-value">T-17</span></div>
      </div>
      <div class="card-footer">
        <button class="btn-help">Request Help</button>
        <span class="critical-note">Visible only in critical status</span>
      </div>
    </div>

    <!-- Waiting Details -->
    <div class="card">
      <div class="card-header">
        <span class="card-title">Waiting Details</span>
        <span class="badge badge-green">Queue Active</span>
      </div>
      <div class="wait-metrics">
        <div class="wait-metric">
          <div class="wait-metric-label">Waiting Time</div>
          <div class="wait-metric-value">32 <span class="wait-unit">min</span></div>
        </div>
        <!-- <div class="wait-metric">
          <div class="wait-metric-label">Estimated Time</div>
          <div class="wait-metric-value" id="countdown" style="font-variant-numeric:tabular-nums;">06:35</div>
        </div> -->
      </div>
      <div class="wait-bar-wrap"><div class="wait-bar" id="wait-bar"></div></div>
      <div class="wait-note">Higher-than-usual wait time. Please remain seated and stay hydrated.</div>
    </div>

    <!-- Sensor Data -->
