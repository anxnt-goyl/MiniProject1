      <div class="card-header">
        <span class="card-title" >Sensor Data</span>
        <span class="badge badge-blue">Real-time</span>
      </div>

      <div class="sensor-grid">

       
        <div class="sensor-chip">
          <div class="sensor-label">Blood Pressure (BP)</div>
          <input type="text" id="bp" placeholder="Enter BP (e.g. 120/80)" required pattern="^\d{2,3}/\d{2,3}$" title="Please enter BP in format Systolic/Diastolic (e.g. 120/80)">
        </div>


   
        <div class="sensor-chip">
          <div class="sensor-label">Temperature</div>
          <input type="number" id="temp" placeholder="Enter temperature" required>
        </div>

    
        <div class="sensor-chip">
          <div class="sensor-label">Heart Rate</div>
          <input type="number" id="hr" placeholder="Enter heart rate" required >
        </div>
         <button onclick="startMonitoring()">Calculate PSS</button>

      <h3>PSS: <span id="pss">--</span></h3>

      <div class="sensor-note">
        Elevated vitals detected. Staff may monitor you more closely.
      </div>
    </div>
      </div> -->
      <div class="card">
  <div class="card-header">
    <span class="card-title">Sensor Data</span>
    <span class="badge badge-blue">Real-time</span>
  </div>

  <div class="sensor-grid">
    <div class="sensor-chip">
      <div class="sensor-label">Blood Pressure (BP)</div>
      <input type="text" id="bp" placeholder="e.g. 120/80" required pattern="^\d{2,3}/\d{2,3}$" title="Enter BP as Systolic/Diastolic">
    </div>
    <div class="sensor-chip">
      <div class="sensor-label">Temperature</div>
      <input type="number" id="temp" placeholder="Enter temperature" required>
    </div>
    <div class="sensor-chip">
      <div class="sensor-label">Heart Rate</div>
      <input type="number" id="hr" placeholder="Enter heart rate" required>
    </div>
  </div>

  <div class="sensor-bottom">
    <button class="btn-pss" onclick="startMonitoring()">Calculate PSS</button>
    <div class="pss-result">
      <span class="pss-label">PSS Score</span>
      <span class="pss-value" id="pss">--</span>
    </div>
  </div>

  
</div>
      

    <!-- Upload Documents -->
    <div class="card">
      <div class="card-header">
        <span class="card-title">Upload Documents</span>
        <span class="badge badge-green">PDF / Images</span>
      </div>
      <label class="upload-area" id="upload-area" for="real-file-input">
        <span class="btn-file">Choose File</span>
        <div class="file-info">
          <span class="file-info-label">Selected file</span>
          <span class="file-info-name" id="file-name-display">No file selected</span>
        </div>
      </label>
      <input type="file" id="real-file-input" accept=".pdf,image/*" style="display:none;" />
      <button class="btn-upload" id="upload-btn" disabled>Upload Document</button>
    </div>


    <div class="popup-overlay" id="popup-overlay">
      <div class="popup-box">
        <div class="popup-icon">✓</div>
        <div class="popup-title">Document Uploaded!</div>
        <div class="popup-msg">Your document has been successfully uploaded and sent for review.</div>
        <button class="popup-close" id="popup-close">Done</button>
      </div>
    </div>

   
    <div class="card" style="grid-column: 1 / -1;">
      <div class="card-header">
        <span class="card-title">Messages</span>
        <span class="badge badge-green">Live</span>
      </div>
      <div class="messages-list" id="messages-list">
        <div class="msg-item"><span class="msg-text">Doctor will attend you soon.</span><span class="msg-time">06:04</span></div>
        <div class="msg-item"><span class="msg-text">High waiting time detected. We apologize for the inconvenience.</span><span class="msg-time">06:04</span></div>
        <div class="msg-item"><span class="msg-text">Your vitals have been reviewed by the triage team.</span><span class="msg-time">05:58</span></div>
      </div>
    </div>

  </div><!-- /grid -->
</main>
<script>
  const pemail = "<%= patient.email %>";
</script>
<script src="/patientDashboard/Patient.js"></script>
</body>
